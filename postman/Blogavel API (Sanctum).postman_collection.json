{
  "info": {
    "name": "Blogavel API (Sanctum)",
    "_postman_id": "b5f7d7c9-6b8d-4b0c-8d1e-8f4f7f1d0a01",
    "description": "Blogavel headless API. Admin endpoints require Sanctum Bearer token.\n\nSet environment variables: base_url, route_prefix, api_version, email, password. Run Auth/Login first to populate token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/{{route_prefix}}/health",
              "host": ["{{base_url}}"],
              "path": ["api", "{{route_prefix}}", "health"]
            }
          }
        }
      ]
    },
    {
      "name": "Public",
      "item": [
        {
          "name": "List Posts",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Accept", "value": "application/json"}
            ],
            "url": {
              "raw": "{{base_url}}/api/{{route_prefix}}/{{api_version}}/posts",
              "host": ["{{base_url}}"],
              "path": ["api", "{{route_prefix}}", "{{api_version}}", "posts"]
            }
          }
        },
        {
          "name": "Get Post (by slug)",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Accept", "value": "application/json"}
            ],
            "url": {
              "raw": "{{base_url}}/api/{{route_prefix}}/{{api_version}}/posts/{{post_slug}}",
              "host": ["{{base_url}}"],
              "path": ["api", "{{route_prefix}}", "{{api_version}}", "posts", "{{post_slug}}"]
            }
          }
        },
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Accept", "value": "application/json"}
            ],
            "url": {
              "raw": "{{base_url}}/api/{{route_prefix}}/{{api_version}}/categories",
              "host": ["{{base_url}}"],
              "path": ["api", "{{route_prefix}}", "{{api_version}}", "categories"]
            }
          }
        },
        {
          "name": "Get Category (by slug)",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Accept", "value": "application/json"}
            ],
            "url": {
              "raw": "{{base_url}}/api/{{route_prefix}}/{{api_version}}/categories/{{category_slug}}",
              "host": ["{{base_url}}"],
              "path": ["api", "{{route_prefix}}", "{{api_version}}", "categories", "{{category_slug}}"]
            }
          }
        },
        {
          "name": "List Tags",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Accept", "value": "application/json"}
            ],
            "url": {
              "raw": "{{base_url}}/api/{{route_prefix}}/{{api_version}}/tags",
              "host": ["{{base_url}}"],
              "path": ["api", "{{route_prefix}}", "{{api_version}}", "tags"]
            }
          }
        },
        {
          "name": "Get Tag (by slug)",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Accept", "value": "application/json"}
            ],
            "url": {
              "raw": "{{base_url}}/api/{{route_prefix}}/{{api_version}}/tags/{{tag_slug}}",
              "host": ["{{base_url}}"],
              "path": ["api", "{{route_prefix}}", "{{api_version}}", "tags", "{{tag_slug}}"]
            }
          }
        },
        {
          "name": "List Approved Comments (threaded)",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Accept", "value": "application/json"}
            ],
            "url": {
              "raw": "{{base_url}}/api/{{route_prefix}}/{{api_version}}/posts/{{post_slug}}/comments",
              "host": ["{{base_url}}"],
              "path": ["api", "{{route_prefix}}", "{{api_version}}", "posts", "{{post_slug}}", "comments"]
            }
          }
        },
        {
          "name": "Create Comment (pending)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Accept", "value": "application/json"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Hello from Postman\",\n  \"guest_name\": \"Jane\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/{{route_prefix}}/{{api_version}}/posts/{{post_slug}}/comments",
              "host": ["{{base_url}}"],
              "path": ["api", "{{route_prefix}}", "{{api_version}}", "posts", "{{post_slug}}", "comments"]
            }
          }
        }
      ]
    },
    {
      "name": "Auth (Sanctum tokens)",
      "item": [
        {
          "name": "Login (issue token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.token) {",
                  "  pm.environment.set('token', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Accept", "value": "application/json"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"device_name\": \"{{device_name}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/{{route_prefix}}/{{api_version}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "{{route_prefix}}", "{{api_version}}", "auth", "login"]
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Accept", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {
              "raw": "{{base_url}}/api/{{route_prefix}}/{{api_version}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "{{route_prefix}}", "{{api_version}}", "auth", "me"]
            }
          }
        },
        {
          "name": "Logout (revoke current token)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Accept", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {
              "raw": "{{base_url}}/api/{{route_prefix}}/{{api_version}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "{{route_prefix}}", "{{api_version}}", "auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Admin (Sanctum protected)",
      "item": [
        {
          "name": "List Comments (pending)",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Accept", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {
              "raw": "{{base_url}}/api/{{route_prefix}}/{{api_version}}/admin/comments?status=pending",
              "host": ["{{base_url}}"],
              "path": ["api", "{{route_prefix}}", "{{api_version}}", "admin", "comments"],
              "query": [{"key": "status", "value": "pending"}]
            }
          }
        },
        {
          "name": "Approve Comment",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Accept", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {
              "raw": "{{base_url}}/api/{{route_prefix}}/{{api_version}}/admin/comments/{{comment_id}}/approve",
              "host": ["{{base_url}}"],
              "path": ["api", "{{route_prefix}}", "{{api_version}}", "admin", "comments", "{{comment_id}}", "approve"]
            }
          }
        },
        {
          "name": "Mark Comment as Spam",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Accept", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {
              "raw": "{{base_url}}/api/{{route_prefix}}/{{api_version}}/admin/comments/{{comment_id}}/spam",
              "host": ["{{base_url}}"],
              "path": ["api", "{{route_prefix}}", "{{api_version}}", "admin", "comments", "{{comment_id}}", "spam"]
            }
          }
        },
        {
          "name": "Delete Comment",
          "request": {
            "method": "DELETE",
            "header": [
              {"key": "Accept", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {
              "raw": "{{base_url}}/api/{{route_prefix}}/{{api_version}}/admin/comments/{{comment_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "{{route_prefix}}", "{{api_version}}", "admin", "comments", "{{comment_id}}"]
            }
          }
        },
        {
          "name": "Create Post",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Accept", "value": "application/json"},
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Postman Post\",\n  \"status\": \"draft\",\n  \"content\": \"Created via Postman\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/{{route_prefix}}/{{api_version}}/admin/posts",
              "host": ["{{base_url}}"],
              "path": ["api", "{{route_prefix}}", "{{api_version}}", "admin", "posts"]
            }
          }
        }
      ]
    }
  ]
}
